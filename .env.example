# Supabase — wajib diisi
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PostgreSQL — untuk direct database access (opsional)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Pollinations.ai — untuk generate cover AI
# Dapatkan key di: https://enter.pollinations.ai
NEXT_PUBLIC_POLLINATIONS_KEY=sk_your_key_here
# MiniMax TTS (direct API) — untuk fitur Text-to-Speech
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=sk-api-your_minimax_key_here

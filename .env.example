# Supabase — wajib diisi
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PostgreSQL — untuk direct database access (opsional)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Google Perspective API — untuk moderasi komentar (opsional)
NEXT_PUBLIC_PERSPECTIVE_API_KEY=your_perspective_key_here

# Self-hosted Indonesian TTS server (Coqui VITS) — lihat /tts-server
LOCAL_TTS_URL=http://localhost:8080

# F5-TTS voice cloning via Hugging Face Space (ZeroGPU) — lihat /tts-clone-space
HF_TOKEN=hf_your_read_token_here
HF_TTS_SPACE=username/your-space-name
